// FileManager OOP
import java.io.*;
import java.util.*;

import javax.swing.JOptionPane;

public class FileManager {
	private static FileManager instance;
	private File file = new File("/home/user/Java_Practices/TaskToDoList/TaskList.txt");
	
	public ArrayList<Tasks> doTasks = new ArrayList<>();
	
		//Private Constructor
		private FileManager() {}
	
	//Singleton Pattern
	public static FileManager GetInstance() {
		if (instance == null) {
			instance = new FileManager();
		}
		return instance;
	}
	// Save
	public void SaveData() {
		try { FileWriter fw = new FileWriter(file);
				for (Tasks tsk : doTasks) {
					fw.write(tsk.getTaskID() + "," + tsk.getTitle() + "," + tsk.getDueDate() + "," + tsk.getStatus() + "\n");
				}
				fw.close();
		} catch (IOException e) {
			JOptionPane.showMessageDialog(null, "Cannot save the file!");
		}
		
	}
	// Load
	public void LoadData() {
		doTasks.clear();
		try { Scanner sc = new Scanner(file);
			while (sc.hasNextLine()) {
				String[] data = sc.nextLine().split(",");
				Tasks task = new Tasks();
				task.SetTasks(Integer.parseInt(data[0]), data[1], data[2], data[3], data[4]);
				doTasks.add(task);
			}
			sc.close();
		} catch (IOException e) {
			JOptionPane.showMessageDialog(null, "Cannot load or the file may not exist!");
		}
	}
}

